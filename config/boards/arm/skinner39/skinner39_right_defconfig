# SPDX-License-Identifier: MIT

CONFIG_INPUT=y
CONFIG_ZMK_MOUSE=y
CONFIG_PMW3610=y
CONFIG_PMW3610_INVERT_X=n
CONFIG_PMW3610_INVERT_Y=y
# 2026-06-10: 旧ファームは右=n だった（カクつきの一因の可能性）。y に変更。
# トラックボールの挙動がおかしければ n に戻す
CONFIG_PMW3610_SMART_ALGORITHM=y
# 2026-06-12: badjeff ドライバに戻したため CPI は dts（cpi = <1200>）で設定。Kconfig の CPI は存在しない

CONFIG_ZMK_EXT_POWER=y
CONFIG_SOC_SERIES_NRF52X=y
CONFIG_SOC_NRF52840_QIAA=y
CONFIG_BOARD_SKINNER39_RIGHT=y

CONFIG_LOG_PROCESS_THREAD_STARTUP_DELAY_MS=4000
CONFIG_ZMK_DISPLAY=y
CONFIG_SPI=y
# Enable MPU
CONFIG_ARM_MPU=y

CONFIG_PINCTRL=y

CONFIG_GPIO=y

CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y

CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y

# 2026-06-10: Windows再接続フリーズ対策（PHY 2M無効・実証済み）。v0.3系でも維持
CONFIG_BT_CTLR_PHY_2M=n
