CONFIG_INPUT=y
CONFIG_ZMK_POINTING=y

CONFIG_LOG_PROCESS_THREAD_STARTUP_DELAY_MS=4000
CONFIG_ZMK_DISPLAY=y
CONFIG_SPI=y
CONFIG_SPI_NRFX=y
CONFIG_ARM_MPU=y

CONFIG_PINCTRL=y

CONFIG_GPIO=y

CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_BUILD_OUTPUT_UF2=y

CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y

CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y
CONFIG_ZMK_SLEEP=y

# 2026-06-05: PC側BTオフ→オン再接続時のフリーズ対策（候補1/Windows再接続安定化）
# 効かなければ戻して CONFIG_ZMK_BLE_EXPERIMENTAL_FEATURES=y を試す
CONFIG_BT_CTLR_PHY_2M=n

# 2026-06-10: ZMK #3195 対策の本命（central が deep sleep から wake しない問題）。
# 6/7 の「Studioなしビルド」は build.yaml の snippet を外しただけで、ここの
# CONFIG_ZMK_STUDIO=y が生きたままだった＝Studio本体(RPC/BLE transport)は有効のままで
# #3195 の回避策（CONFIG_ZMK_STUDIO=n）は実は未適用だった。今回明示的に無効化する。
# Studio を使う時は下2行を =y / =n に戻す（build.yaml の snippet 切り替えも忘れずに）
CONFIG_ZMK_STUDIO=n
# CONFIG_ZMK_STUDIO_LOCKING=n
